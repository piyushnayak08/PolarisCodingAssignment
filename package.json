{
  "name": "polariscodingassignment",
  "version": "1.0.0",
  "description": "Playwright TypeScript automation framework for Practice Software Testing",
  "main": "index.js",
  "scripts": {
    "pw:install": "playwright install --with-deps",
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-chromium",
    "test:api": "playwright test --project=api",
    "test:visual": "playwright test tests/ui/visual-regression.ui.spec.ts --project=ui-chromium",
    "test:visual:update:main": "set TEST_TARGET=main&& playwright test tests/ui/visual-regression.ui.spec.ts --project=ui-chromium --update-snapshots",
    "test:visual:compare:main": "set TEST_TARGET=main&& playwright test tests/ui/visual-regression.ui.spec.ts --project=ui-chromium",
    "test:visual:compare:buggy": "set TEST_TARGET=buggy&& playwright test tests/ui/visual-regression.ui.spec.ts --project=ui-chromium",
    "test:buggy:ui": "set TEST_TARGET=buggy&& playwright test --project=ui-chromium",
    "test:buggy:api": "set TEST_TARGET=buggy&& playwright test --project=api",
    "report:open": "playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "dotenv": "^16.6.1",
    "zod": "^4.3.6"
  }
}
